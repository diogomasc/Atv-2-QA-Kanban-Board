{
  "$schema": "https://www.schemastore.org/tsconfig",
  "display": "Node 22 - Backend",
  "_version": "22.0.0",

  "compilerOptions": {
    "lib": ["es2024", "ESNext.Array", "ESNext.Collection", "ESNext.Iterator"],
    "module": "nodenext",
    "target": "es2022",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node16",

    "outDir": "./dist-backend",
    "rootDir": "./backend"
  },
  "include": ["backend/**/*"],
  "exclude": ["node_modules", "dist", "src"]
}
